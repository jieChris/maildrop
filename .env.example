EMAILENGINE_VERSION=v2.70.0

# Bind to 127.0.0.1 for reverse proxy or SSH tunnel access.
# Change EMAILENGINE_API_BIND to 0.0.0.0 only if you intentionally expose port 3000.
EMAILENGINE_API_BIND=127.0.0.1
EMAILENGINE_API_PORT=3000
EMAILENGINE_SMTP_BIND=127.0.0.1
EMAILENGINE_SMTP_PORT=2525
EMAILENGINE_IMAP_BIND=127.0.0.1
EMAILENGINE_IMAP_PORT=9993

EENGINE_WORKERS=4
EENGINE_LOG_LEVEL=info

# Generate with: openssl rand -hex 32
EENGINE_SECRET=change-me
REDIS_PASSWORD=change-me
